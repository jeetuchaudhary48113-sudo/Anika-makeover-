rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety net: default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Site Config Document rules: Public read, write authorized
    match /site_config/{id} {
      allow get: if true;
      allow list: if true;
      allow write: if true;
    }
  }
}
